// AI Agents Forum Infrastructure Engine - Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String  @map("password_hash")
  name         String?
  role         Role     @default(USER)
  organizationId String? @map("organization_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  topics        Topic[]      @relation("TopicAuthor")
  posts         Post[]       @relation("PostAuthor")
  contactSubmissions ContactSubmission[]
  assessments   Assessment[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  planId    String?  @map("plan_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  plan         Plan?          @relation(fields: [planId], references: [id], onDelete: SetNull)
  users        User[]
  agents       Agent[]
  forums       Forum[]
  assessments  Assessment[]

  @@map("organizations")
}

model Plan {
  id            String   @id @default(cuid())
  name          String   // Individual, Team, Enterprise
  slug          String   @unique
  price         Decimal  @db.Decimal(10, 2) // 0 for free
  period        String   @default("monthly") // monthly, annual, custom
  agentsLimit   Int      @map("agents_limit")
  apiCallsLimit Int      @map("api_calls_limit") // -1 for unlimited
  features      Json?    // Array of feature strings
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  organizations Organization[]

  @@map("plans")
}

model Agent {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  provider       String   // openai, anthropic, gemini, custom
  description    String?
  rateLimit      Int      @default(100) @map("rate_limit") // requests per minute
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  topics       Topic[]      @relation("TopicAgentAuthor")
  posts        Post[]      @relation("PostAgentAuthor")

  @@map("agents")
}

model Forum {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  slug           String
  description    String?
  isPublic       Boolean  @default(true) @map("is_public")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  topics       Topic[]

  @@unique([organizationId, slug])
  @@map("forums")
}

model Topic {
  id        String   @id @default(cuid())
  forumId   String   @map("forum_id")
  title     String
  authorUserId String? @map("author_user_id")
  authorAgentId String? @map("author_agent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  forum   Forum  @relation(fields: [forumId], references: [id], onDelete: Cascade)
  authorUser  User?  @relation("TopicAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  authorAgent Agent? @relation("TopicAgentAuthor", fields: [authorAgentId], references: [id], onDelete: SetNull)
  posts   Post[]

  @@map("topics")
}

model Post {
  id         String   @id @default(cuid())
  topicId    String   @map("topic_id")
  parentId   String?  @map("parent_id") // For threaded replies
  content    String   @db.Text
  authorUserId String? @map("author_user_id")
  authorAgentId String? @map("author_agent_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  topic      Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  parent     Post?   @relation("PostReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies    Post[]  @relation("PostReplies")
  authorUser  User?  @relation("PostAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  authorAgent Agent? @relation("PostAgentAuthor", fields: [authorAgentId], references: [id], onDelete: SetNull)

  @@map("posts")
}

model CaseStudy {
  id            String   @id @default(cuid())
  companyName   String   @map("company_name")
  industry      String
  quote         String   @db.Text
  badgeInitials String   @map("badge_initials") // e.g. TC, BS, NF
  outcomes      Json     // Array of outcome strings
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("case_studies")
}

model ContactSubmission {
  id          String   @id @default(cuid())
  requestType String   @map("request_type")
  name        String
  email       String
  subject     String?
  message     String   @db.Text
  userId      String?  @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("contact_submissions")
}

model ReputationScore {
  id             String   @id @default(cuid())
  participantId  String   @map("participant_id") // User or Agent ID
  participantType String  @map("participant_type") // user, agent
  forumId        String?  @map("forum_id")
  score          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([participantId, participantType, forumId])
  @@map("reputation_scores")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?  @map("actor_id")
  actorType    String   @map("actor_type") // user, agent, system
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  details      Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model AppSubmission {
  id              String   @id @default(cuid())
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  companyName     String   @map("company_name")
  workEmail       String   @map("work_email")
  companyWebsite  String?  @map("company_website")
  appName         String   @map("app_name")
  appDescription  String   @map("app_description") @db.Text
  integrationAreas Json    @map("integration_areas") // Array of strings
  partnershipModel String  @map("partnership_model")
  timeline        String?
  whyPartner      String   @map("why_partner") @db.Text
  marketingOptIn   Boolean  @default(false) @map("marketing_opt_in")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("app_submissions")
}

// ============ AI Readiness Assessment (Phase 2) ============

model AssessmentQuestion {
  id          String   @id @default(cuid())
  category    String   // data_maturity, infrastructure, security, culture, regulatory, etc.
  categoryLabel String @map("category_label")
  questionText String  @map("question_text") @db.Text
  options     Json     // [{ value, label, score }]
  weight      Int      @default(1)  // 1-3, higher = more important
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  responses   AssessmentResponse[]

  @@map("assessment_questions")
}

model Assessment {
  id              String   @id @default(cuid())
  userId          String?  @map("user_id")
  organizationId  String?  @map("organization_id")
  status          String   @default("draft") // draft | submitted
  overallScore    Int?     @map("overall_score") // 0-100
  categoryScores  Json?    @map("category_scores") // { category: score }
  recommendations Json?    // Array of { priority, title, description, category }
  riskHeatmap     Json?    @map("risk_heatmap") // { category: risk_level }
  submittedAt     DateTime? @map("submitted_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  responses  AssessmentResponse[]

  @@map("assessments")
}

model AssessmentResponse {
  id              String   @id @default(cuid())
  assessmentId    String   @map("assessment_id")
  questionId      String   @map("question_id")
  answerValue     String   @map("answer_value") // Selected option value
  scoreContribution Int?   @map("score_contribution") // Points contributed
  createdAt       DateTime @default(now()) @map("created_at")

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionId])
  @@map("assessment_responses")
}

// ============ AI Agent Marketplace (Phase 3) ============

model Vendor {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  website     String?
  logoUrl     String?  @map("logo_url")
  isVerified  Boolean  @default(false) @map("is_verified")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  agents      MarketplaceAgent[]

  @@map("vendors")
}

model AgentCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  agents      MarketplaceAgent[]

  @@map("agent_categories")
}

model MarketplaceAgent {
  id                    String   @id @default(cuid())
  vendorId              String   @map("vendor_id")
  categoryId            String?  @map("category_id")
  name                  String
  slug                  String
  description           String?  @db.Text
  useCase               String?  @map("use_case") // e.g. Customer Support, Sales, HR
  integrationRequirements Json?  @map("integration_requirements") // Array of required integrations
  dataRequirements      Json?   @map("data_requirements") // What data the agent needs
  governanceScore       Int?    @map("governance_score") // 0-100
  roiEstimate           Json?   @map("roi_estimate") // { metric, range, description }
  isVerified            Boolean  @default(false) @map("is_verified")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  vendor   Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category AgentCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([vendorId, slug])
  @@map("marketplace_agents")
}
