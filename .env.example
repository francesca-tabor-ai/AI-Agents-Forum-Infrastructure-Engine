# Database - required for the application to run
DATABASE_URL="postgresql://user:password@localhost:5432/ai_agents_forum"

# JWT signing - REQUIRED in production. Use a secure random string (e.g. openssl rand -base64 32)
JWT_SECRET="your-secret-key-change-in-production"

# Optional: customize seeded admin credentials (default: admin@aiagentsforum.com / Admin123!)
# ADMIN_EMAIL=admin@yourcompany.com
# ADMIN_PASSWORD=YourSecurePassword123!

# Optional: server port (default: 3000)
# PORT=3000
